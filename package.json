{
  "name": "advanced-rag-platform",
  "version": "0.1.0",
  "description": "Generic, modular, enterprise-grade RAG platform (Node.js + TypeScript + LangChain.js + LangGraph.js + OpenAI)",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p .",
    "start": "node dist/server.js",
    "ingest": "tsx scripts/ingest.ts",
    "query": "tsx scripts/query.ts",
    "eval": "tsx scripts/eval.ts",
    "podman:up": "bash scripts/podman-up.sh",
    "podman:down": "bash scripts/podman-down.sh",
    "podman:status": "podman ps --filter network=rag-platform",
    "db:migrate": "tsx scripts/migrate.ts",
    "prisma:build": "tsx prisma/build.ts",
    "prisma:generate": "prisma generate --schema=prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema=prisma/schema.prisma",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run src/tests/unit",
    "test:integration": "vitest run src/tests/integration",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'lint placeholder'"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.665.0",
    "@elastic/elasticsearch": "^8.15.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/helmet": "^12.0.0",
    "@fastify/sensible": "^6.0.0",
    "@langchain/community": "latest",
    "@langchain/core": "^1.0.0",
    "@langchain/langgraph": "^1.0.0",
    "@langchain/langgraph-checkpoint-postgres": "^0.1.0",
    "@langchain/openai": "latest",
    "@langchain/qdrant": "^1.0.0",
    "@langchain/textsplitters": "latest",
    "@prisma/client": "^5.22.0",
    "@qdrant/js-client-rest": "^1.12.0",
    "@types/jsonwebtoken": "^9.0.10",
    "bullmq": "^5.21.0",
    "cheerio": "^1.0.0",
    "dotenv": "^16.4.5",
    "fastify": "^5.0.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.3",
    "langchain": "^1.0.0",
    "langsmith": "^0.3.0",
    "mammoth": "^1.8.0",
    "pdf-parse": "^1.1.1",
    "pg": "^8.13.0",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "prisma": "^5.22.0",
    "tiktoken": "^1.0.20",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.16.0",
    "@types/pdf-parse": "^1.1.4",
    "@types/pg": "^8.11.10",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
