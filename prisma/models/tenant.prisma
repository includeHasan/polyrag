// ============================================================================
// prisma/models/tenant.prisma
// Tenant entity and per-tenant configuration overrides.
// Composed into schema.prisma by prisma/build.ts.
// ============================================================================

enum TenantStatus {
  ACTIVE
  SUSPENDED
}

model Tenant {
  id        String       @id @default(uuid()) @db.Uuid
  slug      String       @unique  // URL-safe identifier e.g. "acme-legal"
  name      String
  status    TenantStatus @default(ACTIVE)
  createdAt DateTime     @default(now()) @db.Timestamptz
  updatedAt DateTime     @updatedAt @db.Timestamptz

  config TenantConfig?

  @@index([slug])
  @@index([status])
  @@map("tenants")
}

/// Per-tenant configuration overrides.
/// The `config` JSON column holds a TenantConfigOverrides object (partial
/// ResolvedTenantConfig). Global env defaults fill any absent keys.
/// Bump `version` on every update to invalidate cached resolved configs.
model TenantConfig {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @unique @db.Uuid
  config   Json   @default("{}")  // TenantConfigOverrides partial
  version  Int    @default(1)      // bumped on each update; used as cache key

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("tenant_configs")
}
