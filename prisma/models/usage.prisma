// ============================================================================
// prisma/models/usage.prisma
// Per-tenant usage metering records (PRD §17, Phase 5).
//
// `usage_events` is a write-heavy append-only log used to track tokens,
// cost, and latency for billing and capacity planning. It is intentionally
// denormalised: a row per (tenant, user, action) call. Aggregations are
// done on read in the billing endpoint and in any future analytics job.
// Composed into schema.prisma by prisma/build.ts.
// ============================================================================

/// One row per billable / metered API call. Records a single
/// (tenant, user, action) invocation with token + cost + latency.
model UsageEvent {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String?  @db.Uuid
  userId     String?  @db.Uuid
  action     String   // e.g. "query", "ingest", "search", "reindex"
  tokensUsed Int      @default(0)
  costUsd    Float    @default(0)
  latencyMs  Int      @default(0)
  metadata   Json     @default("{}")
  createdAt  DateTime @default(now()) @db.Timestamptz

  @@index([tenantId, createdAt])
  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@index([createdAt])
  @@map("usage_events")
}
