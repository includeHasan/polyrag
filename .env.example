# ============================================================================
# Advanced RAG Platform — Environment Configuration
# Copy to .env and fill in real values.
# ============================================================================

# --- LLM Provider ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL_GENERATION=gpt-4o
OPENAI_MODEL_EVALUATION=gpt-4o-mini
OPENAI_MODEL_RERANK=gpt-4o-mini

# --- Embeddings ---
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIM=1536

# --- LangSmith (Observability) ---
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=lsv2_pt_...
LANGSMITH_PROJECT=advanced-rag-platform
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# --- Qdrant (Vector DB) ---
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=chunks

# --- Postgres (RDBMS + Checkpointing) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=rag
POSTGRES_PASSWORD=rag
POSTGRES_DB=rag
# DATABASE_URL is consumed by Prisma — keep in sync with the above.
DATABASE_URL=postgresql://rag:rag@localhost:5432/rag

# --- Redis (Cache + Queue) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Elasticsearch (Keyword Search) ---
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=
ELASTICSEARCH_INDEX=chunks

# --- S3 / MinIO (Object Storage) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=rag-documents
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# --- Retrieval Defaults ---
RETRIEVAL_TOP_K=10
RETRIEVAL_RERANK_TOP_K=20
RERANKER_ENABLED=false
HYBRID_SEARCH_ENABLED=false

# --- Chunking Defaults ---
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
CHUNKER_STRATEGY=recursive

# --- Server ---
SERVER_HOST=0.0.0.0
SERVER_PORT=3000
LOG_LEVEL=info
NODE_ENV=development

# --- Security (Phase 5) ---
JWT_SECRET=change-me-in-prod
JWT_EXPIRES_IN=24h
